@model List<UmbracoTestBootcamp.Models.Student.Student>
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Student List</title>
    <style>
        body {
            font-family: Arial;
            padding: 20px;
        }

        .student-card {
            border: 1px solid #ccc;
            border-radius: 8px;
            padding: 15px;
            margin: 10px 0;
            width: 300px;
        }

            .student-card h2 {
                margin: 0 0 10px 0;
                color: #333;
            }

            .student-card p {
                margin: 5px 0;
                color: #666;
            }

            .student-card ul {
                margin: 0 0 10px 0;
                color: #333;
            }

            .student-card li {
                margin: 5px 0;
                color: #666;
            }
    </style>
</head>
<body>

    <h1>Student List</h1>
    <p>Total students: @Model.Count</p>

    <div style="display: flex; flex-direction: row; flex-wrap: wrap; gap: 36px;">
        @if (!Model.Any())
        {
            <p>No students found.</p>
        }
        else
        {
            @foreach (var student in Model)
            {

                <div class="student-card">
                    <h2>@student.Name</h2>
                    <p>Id: @student.Id</p>
                    <p>Email: @student.Email</p>
                    <p>Age: @student.Age</p>
                    <p>Date of Birth: @student.DateOfBirth</p>
                    <br />
                    <p><strong>CARS</strong></p>
                    @if (student.StudentsCar != null && student.StudentsCar.Count > 0)
                    {
                        <ol>
                            @foreach (var car in student.StudentsCar)
                            {
                                <li>
                                    <strong>Name: @car.Name</strong>
                                    <ul>
                                        <li>Id: @car.Id</li>
                                        <li>Make: @car.Make</li>
                                        <li>Model: @car.Model</li>
                                        <li>Year: @car.Year</li>
                                        <li>Price: RM @car.Price</li>
                                    </ul>
                                </li>
                            }
                        </ol>
                    }

                    <!-- Link to individual student page -->
                    <a href="/students/viewstudent/@student.Id">
                        View Details
                    </a>
                </div>
            }
        }

    </div>

</body>
</html>
